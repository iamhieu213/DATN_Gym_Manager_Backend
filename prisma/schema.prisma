generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  COACH
  STAFF
  USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum OtpType {
  REGISTER
  FORGOT_PASSWORD
  VERIFY_EMAIL
}

model User {
  id                Int          @id @default(autoincrement())
  email             String       @unique @db.VarChar(255)
  passwordHash      String?      @map("password_hash") @db.VarChar(255)
  name              String       @db.VarChar(255)
  phone             String?      @unique @db.VarChar(30)
  dateOfBirth       DateTime?    @map("date_of_birth")
  emailVerifiedAt   DateTime?    @map("email_verified_at")

  role              UserRole     @default(USER)
  status            UserStatus   @default(ACTIVE)

  googleId          String?      @unique @map("google_id") @db.VarChar(255)

  // New profile fields
  avatarUrl         String?      @map("avatar_url") @db.VarChar(255)
  gender            Gender?
  citizenId         String?      @unique @map("citizen_id") @db.VarChar(50)
  address           String?      @db.VarChar(255)
  emergencyContact  String?      @map("emergency_contact") @db.VarChar(255)

  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  refreshTokens     RefreshToken[]
  otpVerifications  OtpVerification[]

  @@map("users")

  @@index([email])
  @@index([role, status])
}

model RefreshToken {
  id          Int       @id @default(autoincrement())

  userId      Int       @map("user_id")

  token       String    @unique @db.Text
  tokenId     String    @unique @map("token_id") @db.Uuid

  expiresAt   DateTime  @map("expires_at")
  isRevoked   Boolean   @default(false) @map("is_revoked")

  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")

  @@index([userId])
  @@index([expiresAt])
  @@index([isRevoked])
}

model OtpVerification {
  id          Int       @id @default(autoincrement())

  userId      Int?      @map("user_id")

  email       String    @db.VarChar(255)

  otpCode     String    @map("otp_code") @db.VarChar(20)

  type        OtpType

  expiresAt   DateTime  @map("expires_at")

  isUsed      Boolean   @default(false) @map("is_used")

  createdAt   DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("otp_verifications")

  @@index([email, type, isUsed, expiresAt])
  @@index([userId])
}